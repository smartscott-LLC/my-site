---
import { cn } from '@/lib/cn';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<!-- 3-state colour-mode cycler. Click cycles: system → light → dark → system.
     The visible icon is driven by <html data-theme-mode="…"> so it stays in
     sync with the inline bootstrap (no FOUC of the wrong icon). -->
<button
  type="button"
  id="theme-toggle"
  class={cn(
    'theme-toggle inline-flex items-center justify-center rounded-md p-2',
    'text-muted-foreground hover:text-foreground hover:bg-secondary',
    'transition-colors duration-(--transition-fast)',
    'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2',
    className
  )}
  aria-label="Theme: system"
  title="Theme: system (click to cycle)"
>
  <!-- Monitor icon — shown when mode === 'system' -->
  <svg
    class="theme-toggle__icon theme-toggle__icon--system h-5 w-5"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
  >
    <rect x="2.75" y="3.75" width="18.5" height="13" rx="2" />
    <path stroke-linecap="round" d="M8 20.25h8M12 16.75v3.5" />
  </svg>

  <!-- Sun icon — shown when mode === 'light' -->
  <svg
    class="theme-toggle__icon theme-toggle__icon--light h-5 w-5"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"
    />
  </svg>

  <!-- Moon icon — shown when mode === 'dark' -->
  <svg
    class="theme-toggle__icon theme-toggle__icon--dark h-5 w-5"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"
    />
  </svg>
</button>

<style>
  /* Show exactly one icon based on the saved colour-mode. The bootstrap
     sets data-theme-mode synchronously before paint, so the right icon is
     visible from frame 0 (no flash). */
  .theme-toggle__icon { display: none; }
  :global(html[data-theme-mode='system']) .theme-toggle .theme-toggle__icon--system,
  :global(html[data-theme-mode='light'])  .theme-toggle .theme-toggle__icon--light,
  :global(html[data-theme-mode='dark'])   .theme-toggle .theme-toggle__icon--dark {
    display: block;
  }
</style>

<script>
  type Mode = 'system' | 'light' | 'dark';
  const MODES: readonly Mode[] = ['system', 'light', 'dark'] as const;

  function readMode(): Mode {
    try {
      const stored = localStorage.getItem('theme');
      if (stored === 'system' || stored === 'light' || stored === 'dark') return stored;
    } catch {
      /* private mode */
    }
    return 'system';
  }

  function applyMode(mode: Mode): void {
    const root = document.documentElement;
    root.setAttribute('data-theme-mode', mode);
    const isDark =
      mode === 'dark' ||
      (mode === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
    root.classList.toggle('dark', isDark);
  }

  function syncLabel(button: HTMLElement, mode: Mode): void {
    button.setAttribute('aria-label', `Theme: ${mode}`);
    button.setAttribute('title', `Theme: ${mode} (click to cycle)`);
  }

  function initThemeToggle(): void {
    const toggle = document.getElementById('theme-toggle');
    if (!toggle || toggle.dataset.themeInit) return;
    toggle.dataset.themeInit = 'true';

    syncLabel(toggle, readMode());

    toggle.addEventListener('click', () => {
      const current = readMode();
      const next = MODES[(MODES.indexOf(current) + 1) % MODES.length];

      try {
        localStorage.setItem('theme', next);
      } catch {
        /* private mode */
      }
      applyMode(next);
      syncLabel(toggle, next);
    });
  }

  // Run on initial load and after every view-transition swap
  initThemeToggle();
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>
