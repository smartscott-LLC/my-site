---
import ServicesView from '@/components/pages/views/ServicesView.astro';
import { getSecondaryLocales } from '@/i18n';

// Locale-prefixed Services page (`/<locale>/services`). One page per non-default
// locale; emits nothing when i18n is off. Untranslated copy falls back to the
// default locale so the LanguageSwitcher never lands on a 404.
export function getStaticPaths() {
  return getSecondaryLocales().map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
---

<ServicesView locale={locale} />
