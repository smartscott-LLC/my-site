---
import HomeView from '@/components/pages/views/HomeView.astro';
import { getSecondaryLocales } from '@/i18n';

// Locale-prefixed landing page (`/<locale>`). One page per non-default locale;
// emits nothing when i18n is off. Featured content and copy fall back to the
// default locale, so the LanguageSwitcher never lands on a 404.
export function getStaticPaths() {
  return getSecondaryLocales().map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
---

<HomeView locale={locale} />
